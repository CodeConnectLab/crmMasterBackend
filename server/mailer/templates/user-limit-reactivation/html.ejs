<table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="margin:0;padding:0;background-color:#fef3c7;">
  <tr>
    <td align="center" style="padding:24px 12px;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Arial,sans-serif;">
      <!-- max width wrapper -->
      <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="max-width:600px;background:#ffffff;border-radius:14px;overflow:hidden;box-shadow:0 8px 30px rgba(120,53,15,0.12);">

        <!-- header -->
        <tr>
          <td style="background:linear-gradient(135deg,#92400e 0%,#b45309 50%,#d97706 100%);padding:28px 24px;color:#ffffff;">
            <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
              <tr>
                <% if (goConnectLogoUrl) { %>
                  <td align="center" style="padding-bottom:12px;">
                    <img src="<%= goConnectLogoUrl %>" alt="Code Connect" width="140" height="auto" style="display:block;margin:0 auto;max-height:40px;width:auto;">
                  </td>
                <% } else { %>
                  <td align="center" style="font-size:20px;font-weight:700;letter-spacing:0.03em;padding-bottom:4px;">Code Connect</td>
                <% } %>
              </tr>
              <tr>
                <% if (connectCrmLogoUrl) { %>
                  <td align="center" style="padding-bottom:4px;">
                    <img src="<%= connectCrmLogoUrl %>" alt="Connect CRM" width="120" height="auto" style="display:block;margin:0 auto;max-height:32px;width:auto;">
                  </td>
                <% } else { %>
                  <td align="center" style="font-size:15px;font-weight:600;opacity:0.9;">Connect CRM</td>
                <% } %>
              </tr>
              <tr>
                <td align="center" style="font-size:12px;padding-top:8px;opacity:0.9;">Employee reactivation notice</td>
              </tr>
            </table>
          </td>
        </tr>

        <!-- distinguishing banner -->
        <tr>
          <td style="background:#fef3c7;border-top:1px solid #fde68a;border-bottom:1px solid #fde68a;padding:14px 24px;text-align:center;color:#92400e;font-weight:700;font-size:13px;letter-spacing:0.08em;text-transform:uppercase;">
            ⚠ Employee reactivated — seat limit exceeded
          </td>
        </tr>

        <!-- body -->
        <tr>
          <td style="padding:28px 24px;color:#334155;line-height:1.55;font-size:15px;">
            <h1 style="margin:0 0 16px;font-size:22px;line-height:1.3;color:#0f172a;font-weight:700;">Employee reactivated beyond seat limit</h1>
            <p style="margin:0 0 20px;color:#475569;font-size:15px;">
              An inactive employee was switched back to active for the company below. The reactivation has restored a seat above your current subscription allocation. The next billing cycle amount may increase as a result of this change.
            </p>

            <% if (companyLogoUrl) { %>
              <table role="presentation" cellspacing="0" cellpadding="0" border="0" style="margin:0 auto 24px;">
                <tr>
                  <td align="center" style="padding:12px;border:1px solid #e2e8f0;border-radius:12px;background:#fafafa;">
                    <img src="<%= companyLogoUrl %>" alt="<%= companyName %>" width="120" height="auto" style="display:block;margin:0 auto;border-radius:8px;">
                  </td>
                </tr>
              </table>
            <% } %>

            <!-- company block -->
            <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="margin-bottom:20px;border:1px solid #e2e8f0;border-radius:12px;overflow:hidden;">
              <tr>
                <td colspan="2" style="padding:14px 16px;background:#f8fafc;font-weight:700;font-size:13px;color:#0f172a;text-transform:uppercase;letter-spacing:0.04em;">Company &amp; subscription</td>
              </tr>
              <tr>
                <td style="padding:12px 16px;color:#64748b;font-size:13px;width:42%;vertical-align:top;border-top:1px solid #f1f5f9;">Company name</td>
                <td style="padding:12px 16px;color:#0f172a;font-weight:600;font-size:14px;border-top:1px solid #f1f5f9;"><%= companyName %></td>
              </tr>
              <tr>
                <td style="padding:12px 16px;color:#64748b;font-size:13px;vertical-align:top;border-top:1px solid #f1f5f9;">Plan</td>
                <td style="padding:12px 16px;color:#0f172a;font-size:14px;border-top:1px solid #f1f5f9;"><%= subscriptionPlanLabel %> <span style="color:#94a3b8;font-weight:400;">(<%= subscriptionPlanRaw %>)</span></td>
              </tr>
              <tr>
                <td style="padding:12px 16px;color:#64748b;font-size:13px;vertical-align:top;border-top:1px solid #f1f5f9;">Subscription expiry</td>
                <td style="padding:12px 16px;color:#0f172a;font-size:14px;border-top:1px solid #f1f5f9;"><%= subscriptionEndDateFormatted %></td>
              </tr>
              <tr>
                <td style="padding:12px 16px;color:#64748b;font-size:13px;vertical-align:top;border-top:1px solid #f1f5f9;">Allowed user seats</td>
                <td style="padding:12px 16px;color:#0f172a;font-size:14px;border-top:1px solid #f1f5f9;"><%= userLimitAllocated %></td>
              </tr>
              <tr>
                <td style="padding:12px 16px;color:#64748b;font-size:13px;vertical-align:top;border-top:1px solid #f1f5f9;">Active users before</td>
                <td style="padding:12px 16px;color:#0f172a;font-size:14px;border-top:1px solid #f1f5f9;"><%= activeBefore %></td>
              </tr>
              <tr>
                <td style="padding:12px 16px;color:#64748b;font-size:13px;vertical-align:top;border-top:1px solid #f1f5f9;">Active users after</td>
                <td style="padding:12px 16px;color:#b45309;font-weight:700;font-size:14px;border-top:1px solid #f1f5f9;"><%= activeAfter %></td>
              </tr>
            </table>

            <!-- reactivated user -->
            <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="margin-bottom:20px;border:1px solid #fde68a;border-radius:12px;overflow:hidden;">
              <tr>
                <td colspan="2" style="padding:14px 16px;background:#fef3c7;font-weight:700;font-size:13px;color:#92400e;text-transform:uppercase;letter-spacing:0.04em;">Reactivated user</td>
              </tr>
              <tr>
                <td style="padding:12px 16px;color:#64748b;font-size:13px;width:42%;vertical-align:top;border-top:1px solid #fef9c3;">Name</td>
                <td style="padding:12px 16px;color:#0f172a;font-weight:600;font-size:14px;border-top:1px solid #fef9c3;"><%= reactivatedUserName %></td>
              </tr>
              <tr>
                <td style="padding:12px 16px;color:#64748b;font-size:13px;vertical-align:top;border-top:1px solid #fef9c3;">Email</td>
                <td style="padding:12px 16px;color:#b45309;font-size:14px;border-top:1px solid #fef9c3;"><a href="mailto:<%= reactivatedUserEmail %>" style="color:#b45309;text-decoration:none;"><%= reactivatedUserEmail %></a></td>
              </tr>
              <tr>
                <td style="padding:12px 16px;color:#64748b;font-size:13px;vertical-align:top;border-top:1px solid #fef9c3;">Phone</td>
                <td style="padding:12px 16px;color:#0f172a;font-size:14px;border-top:1px solid #fef9c3;"><%= reactivatedUserPhone %></td>
              </tr>
              <tr>
                <td style="padding:12px 16px;color:#64748b;font-size:13px;vertical-align:top;border-top:1px solid #fef9c3;">Role</td>
                <td style="padding:12px 16px;color:#0f172a;font-size:14px;border-top:1px solid #fef9c3;"><%= reactivatedUserRole %></td>
              </tr>
              <tr>
                <td style="padding:12px 16px;color:#64748b;font-size:13px;vertical-align:top;border-top:1px solid #fef9c3;">Reactivated by</td>
                <td style="padding:12px 16px;color:#0f172a;font-size:14px;border-top:1px solid #fef9c3;"><%= reactivatedByName %><br><span style="color:#64748b;font-size:13px;"><%= reactivatedByEmail %></span></td>
              </tr>
            </table>

            <p style="margin:0 0 24px;font-size:13px;color:#64748b;">
              <strong style="color:#475569;">Timestamp (UTC)</strong><br><%= timestampUtc %>
            </p>

            <!-- CTA -->
            <table role="presentation" cellspacing="0" cellpadding="0" border="0" align="center" style="margin:0 auto 24px;">
              <tr>
                <td style="border-radius:10px;background:linear-gradient(135deg,#b45309,#92400e);">
                  <a href="<%= appDashboardUrl %>" target="_blank" rel="noopener noreferrer" style="display:inline-block;padding:14px 28px;font-size:15px;font-weight:600;color:#ffffff;text-decoration:none;">Open dashboard</a>
                </td>
              </tr>
            </table>

            <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="background:#fffbeb;border:1px solid #fde68a;border-radius:10px;margin-bottom:0;">
              <tr>
                <td style="padding:16px 18px;font-size:14px;color:#713f12;">
                  <strong style="display:block;margin-bottom:6px;color:#92400e;">Billing impact</strong>
                  Reactivating this employee has restored a seat above your current plan allocation. Renewal or invoiced amounts may differ on the next cycle. Coordinate with billing or account management if pricing needs to be reconciled proactively.
                </td>
              </tr>
            </table>
          </td>
        </tr>

        <!-- footer -->
        <tr>
          <td style="padding:20px 24px;background:#f8fafc;border-top:1px solid #e2e8f0;font-size:12px;color:#64748b;line-height:1.6;text-align:center;">
            <strong style="color:#475569;display:block;margin-bottom:6px;">Code Connect · Connect CRM</strong>
            Need help?
            <a href="mailto:<%= supportEmail %>" style="color:#b45309;font-weight:600;text-decoration:none;"><%= supportEmail %></a>
            <span style="color:#cbd5e1;"> &nbsp;|&nbsp; </span>
            Powered by trusted CRM infrastructure — please keep this notification confidential.
          </td>
        </tr>
      </table>
    </td>
  </tr>
</table>
